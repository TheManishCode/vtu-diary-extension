{
  "manifest_version": 3,
  "name": "Diary Made Easy [VTU]",
  "short_name": "EasyDiary",
  "description": "VTU internship diary assistant to generate entries, bulk upload JSON, fetch diaries, and export clean PDF reports. Includes optional affiliate links for student tools.",
  "version": "3.0.2",
  "permissions": ["activeTab", "scripting", "downloads", "storage"],
  "host_permissions": [
    "https://vtu.internyet.in/*",
    "https://vtuapi.internyet.in/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Diary Made Easy [VTU]",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/jspdf.umd.min.js"],
      "matches": ["https://vtu.internyet.in/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
